#!/bin/bash
set -euo pipefail

# tomei manifest hashes (triggers re-run on change):
# {{ include "dot_config/tomei/common-tools.cue" | sha256sum }}
# {{ include "dot_config/tomei/tomei_platform.cue" | sha256sum }}
# {{ include "dot_config/tomei/runtimes.cue" | sha256sum }}
# {{ include "dot_config/tomei/lang-tools.cue" | sha256sum }}
# {{ include "dot_config/tomei/darwin2-extras.cue.tmpl" | sha256sum }}

TOMEI_DIR="${HOME}/.config/tomei"

if ! command -v tomei &>/dev/null; then
    echo "WARN: tomei not found, skipping"
    exit 0
fi

if [ ! -d "$TOMEI_DIR" ]; then
    echo "WARN: $TOMEI_DIR not found, skipping"
    exit 0
fi

tomei init --yes
tomei validate "$TOMEI_DIR"

if [ "${SKIP_TOMEI_APPLY:-}" = "true" ]; then
    echo "Skipping tomei apply (SKIP_TOMEI_APPLY=true)"
else
    tomei apply --yes "$TOMEI_DIR" || echo "WARN: tomei apply exited with errors (some tools may have failed)"
    echo "tomei apply completed"
fi
