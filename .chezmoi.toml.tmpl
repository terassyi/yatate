{{- /* ホスト情報の取得 */ -}}
{{- $hostname := .chezmoi.hostname -}}
{{- $os := .chezmoi.os -}}
{{- $username := .chezmoi.username -}}

{{- /* CI/テスト環境のオーバーライド (runner: GitHub Actions, testuser: コンテナテスト) */ -}}
{{- if or (eq $username "runner") (eq $username "testuser") -}}
  {{- $hostname = "dev" -}}
{{- end -}}

{{- /* デスクトップ環境の判定 */ -}}
{{- $headless := true -}}
{{- if eq $os "darwin" -}}
  {{- $headless = false -}}
{{- else if or (eq $hostname "teracarbon") (eq $hostname "teradev") -}}
  {{- $headless = false -}}
{{- else if eq $hostname "devvm" -}}
  {{- $headless = false -}}
{{- end -}}

{{- /* プロファイル判定 (personal / work / test) */ -}}
{{- $profile := "personal" -}}
{{- if or (eq $hostname "fukdesk") (eq $hostname "darwin2") -}}
  {{- $profile = "work" -}}
{{- end -}}
{{- if or (eq $username "runner") (eq $username "testuser") -}}
  {{- $profile = "test" -}}
{{- end -}}

encryption = "age"

[edit]
command = "nvim"

[diff]
pager = "delta"

[merge]
command = "nvim"
args = ["-d"]

[age]
identity = "~/.config/chezmoi/key-{{ $profile }}.txt"
{{- if eq $profile "work" }}
recipient = "age1p4kg9mlawasn4dh9ug8xndptnry0yu6ec7nhtwvk0la3qzm3dy4qmh88e8"
{{- else if eq $profile "personal" }}
recipient = "age1jlp689wyctgklkajtllwwspmuz9c9mmntd9l279trx2r9vushstqnga25d"
{{- else }}
recipient = "age148yv50pmelaed8wt2yykc57ycv74jm9wc6l6udg9ekx82qc2pq4qqyfalq"
{{- end }}

[data]
hostname  = "{{ $hostname }}"
username  = "{{ $username }}"
os        = "{{ $os }}"
headless  = {{ $headless }}
is_darwin = {{ eq $os "darwin" }}
is_linux  = {{ eq $os "linux" }}
profile   = "{{ $profile }}"
{{- if eq $profile "work" }}
skills_repo = "cybozu-private/terashima-skills"
{{- else }}
skills_repo = "terassyi/skills"
{{- end }}
